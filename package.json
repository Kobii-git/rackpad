{
  "name": "rackpad",
  "version": "1.7.2-dev.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "description": "Self-hosted homelab and lab inventory: racks, ports, cables, IPs, devices.",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently -n vite,api -c cyan,yellow \"npm run dev\" \"npm run dev:server\"",
    "build:client": "tsc -b && vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist-server/index.js",
    "test:server": "node --import tsx --test server/tests/**/*.test.ts",
    "test:client": "node --import tsx --test src/pages/visualizer/model.test.ts",
    "test:e2e": "playwright test",
    "test": "npm run check:i18n && npm run test:server && npm run test:client && npm run test:e2e",
    "lint": "eslint .",
    "check:i18n": "node scripts/check-i18n-values.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check": "npm run lint && npm run test && npm run build && npm run check:bundle",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@xyflow/react": "^12.11.2",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.10.0",
    "ipaddr.js": "^2.4.0",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "nodemailer": "^9.0.3",
    "pino-pretty": "^13.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.53.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "~7.0.2",
    "vite": "^8.1.5"
  }
}
